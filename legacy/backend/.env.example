# Axion backend — environment template
# Copy to .env and adjust for your machine.

ENV=dev
DEBUG=true
LOG_LEVEL=INFO
REGION=eu-west-3
API_PREFIX=/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30
BCRYPT_ROUNDS=12

# ── Database (Postgres + pgvector) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://axion:axion@localhost:5432/axion
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis & Celery ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM providers (leave empty for stub mode) ──────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
DEFAULT_MODEL=claude-opus-4-7
FALLBACK_MODEL=gpt-4o

# ── Object storage (audit replay) ──────────────────────────────
S3_BUCKET_AUDIT=axion-audit
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Encryption (envelope keys) ─────────────────────────────────
AXION_ENCRYPTION_KEY=replace-with-aws-kms-data-key

# ── Observability ──────────────────────────────────────────────
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=axion-api
