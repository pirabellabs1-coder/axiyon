# Copy to .env.local for development. NEVER commit .env.local.
# In production, set these in Vercel → Project → Settings → Environment Variables.

# ─── Database (Vercel Postgres / Neon) ──────────────────────────
# Provisioned automatically when you add Vercel Postgres to the project.
POSTGRES_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/axion?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/axion?sslmode=require

# ─── Auth (NextAuth v5 / Auth.js) ───────────────────────────────
# `openssl rand -hex 32` for AUTH_SECRET.
AUTH_SECRET=replace-with-32-byte-hex-secret
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ─── LLM providers (at least one required for real agent runs) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Bootstrap super-admin (created on first login if it matches) ──
SUPER_ADMIN_EMAIL=
